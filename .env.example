# Copy this file to .env and fill in the keys you have. Never commit the real .env.
# With no keys, set LLM_PROVIDER=mock (or run with --mock) to use deterministic fixtures.

# Which LLM backend to use: anthropic | openai | mistral | local | mock
LLM_PROVIDER=anthropic

# API keys (leave blank if unused)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=

# Model per provider (sensible defaults are used if left blank)
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-4o
MISTRAL_MODEL=mistral-large-latest

# Local provider via Ollama (used when LLM_PROVIDER=local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Storage
BUILDINGLENS_DB=data/buildinglens.db
